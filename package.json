{
  "name": "rsync2",
  "version": "3.0.1",
  "description": "Rsync cli wrapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhundley9109/rsync"
  },
  "keywords": [
    "rsync",
    "wrapper",
    "cli",
    "command"
  ],
  "author": "Jacob Hundley <jhundley9109@gmail.com>",
  "license": "MIT",
  "readmeFilename": "README.md",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -f index.js",
    "lint": "semistandard \"test/**/*.js\" \"examples/**/*.js\"",
    "test": "npm run build && npm run lint && mocha"
  },
  "dependencies": {
    "cross-spawn": "^7.0.3",
    "unixify": "^1.0.0",
    "which": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "semistandard": "^17.0.0",
    "sinon": "^15.2.0",
    "typescript": "^6.0.3"
  },
  "semistandard": {
    "ignore": [
      "index.js"
    ]
  }
}
